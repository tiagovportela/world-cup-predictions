VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_ADMIN_PASSWORD=your_secret_admin_password

# football-data.org API key for next match + results auto-fetch.
# Get free at: https://www.football-data.org/
# NOTE: no VITE_ prefix — this is read SERVER-SIDE by the Netlify function
# (netlify/functions/football.mjs), so it is never exposed to the browser.
# Local dev: put this in a `.env` file and run `netlify dev` (not `npm run dev`).
FOOTBALL_DATA_KEY=your_api_key
